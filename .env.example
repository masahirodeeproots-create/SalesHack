# =============================================================
# 環境変数テンプレート
# =============================================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
# .env は .gitignore に含まれているため git にはコミットされません。

# --- Database ---
DATABASE_URL=postgresql://localhost:5432/company_db

# --- ScrapingDog API ---
SCRAPINGDOG_API_KEY=your_scrapingdog_api_key_here

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Playwright認証 (HRサービス用) ---
OFFERBOX_EMAIL=
OFFERBOX_PASSWORD=
BIZREACH_EMAIL=
BIZREACH_PASSWORD=

# --- HTTP設定 (オプション) ---
# REQUEST_INTERVAL=1.5
# MAX_RETRIES=3
# RETRY_BACKOFF_BASE=2

# --- GCP / BigQuery ---
# GCP プロジェクト ID（Cloud Run 等の GCP 環境では自動検出される場合あり）
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery データセット名・テーブル名（変更する場合のみ設定）
# BQ_DATASET=company_data
# BQ_TABLE=companies

# true にすると全コレクターが BigQuery にも書き込む
# ローカル開発では false のまま、GCP 環境では true に設定
UPLOAD_TO_BIGQUERY=false

# GCP Secret Manager を使用する場合（GCP 環境での推奨）
# USE_SECRET_MANAGER=false
